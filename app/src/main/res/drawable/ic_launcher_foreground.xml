<?xml version="1.0" encoding="utf-8"?>
<!-- A mihrab-style niche: the same pointed-arch silhouette as ui/theme/Shapes.kt's ArchShape,
     drawn twice (gold frame, emerald recess) so it reads as an architectural niche rather than a
     flat blob. Both arches stay within the 66dp adaptive-icon safe zone (circle of radius 33
     centered at 54,54) so no launcher mask shape clips them. The monochrome themed-icon variant
     reuses this same drawable — both paths are fully opaque, so the system's flat tint just
     collapses them into one solid arch silhouette, which still reads cleanly. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#C9962C"
        android:pathData="M32,74 L76,74 L76,47.3 Q76,33.5 54,28 Q32,33.5 32,47.3 Z" />
    <path
        android:fillColor="#123F31"
        android:pathData="M40,66 L68,66 L68,48.6 Q68,39.6 54,36 Q40,39.6 40,48.6 Z" />
</vector>
